# Perfil: local (desenvolvimento) | qa (OpenShift / infra VTAL)
APP_PROFILE=local

# API
PORT=3333

# --- Perfil local: copie também .env.local.example para .env.local ---
# USE_MEMORY_QUEUE=1
# DATABASE_DRIVER=sqlite
# REDIS_MODE=standalone
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# --- Perfil qa: copie .env.qa.example para .env.qa (não commitar) ---
# DATABASE_DRIVER=mysql
# MYSQL_HOST=10.101.37.168
# REDIS_MODE=sentinel
# REDIS_SENTINEL_HOST=10.101.37.169
# REDIS_MASTER_NAME=TDMQA

# Worker
WORKER_CONCURRENCY=3
JOB_ATTEMPTS=2

# Monitoramento (console + GET /api/monitor + painel na tela Massa)
LOG_MONITOR=1
MONITOR_BUFFER_SIZE=500

# --- OFS (Oracle Field Service) — collection ofsvtal1.test.postman_collection.json ---
# TI:  https://ofsvtal1.test.fs.ocs.oraclecloud.com
# TRG: https://ofsvtal3.test.fs.ocs.oraclecloud.com
# OFS_USERNAME=vt422570
# OFS_PASSWORD=<senha supervisor dispatcher>
# OFS_TECH_PID=881
# OFS_TECH_SEARCH=geraldo
# OFS_TARGET_DATE=2026-06-15
# OFS_BUCKET_PID=3457
# OFS_USE_REST_API=1
# OFS_PULAR_ATIVACAO=1 — pula ativar rota (técnico já ativo; não use no E2E normal)
# Opção A — copiar do DevTools após login (válido até expirar):
# OFS_UI_COOKIE=id=...; token=...; ofsc42=...
# OFS_UI_CSRF=<header x-ofs-csrf-secure>
# OFS_UI_TRUST=$fast$sha256$...
#
# Opção B — login automático (recomendado):
# OFS_USERNAME=vt422570
# OFS_PASSWORD=...
# node scripts/run-ofs-ui-login-playwright.js   → salva .auth/<env>/ofs-ui-session.json
# HTTP sozinho renova cookie; CSRF/trust vêm do Playwright ou DevTools.
# OFS_UI_SKIP_AUTO_LOGIN=1 — desliga renovação automática
# OFS_UI_USER=VT422570
# OFS_BUCKET_PID=3457
# OFS_TECH_PID=881
# OFS_PULAR_ATIVACAO=1 — só diagnóstico (E2E normal precisa ativar rota antes do start)
# OFS_UI_QUEUE_PLACEHOLDER_AID=-1465 — aid sintético da fila (mobile_activate_queue)
# OFS_UI_ACTIVATE_ACTION_CODE=253
# OFS_UI_ACTIVATE_QUEUE_AID=9
# OFS_UI_CANCEL_ACTION_CODE=309
# OFS_UI_CANCEL_QUEUE_AID=10
# OFS_UI_MEAL_WORKTYPE=2
# OFS_TI_BASE_URL=https://ofsvtal1.test.fs.ocs.oraclecloud.com
# OFS_TRG_BASE_URL=https://ofsvtal3.test.fs.ocs.oraclecloud.com
