# TDM-QA — OpenShift / infra empresa
# Copie para .env.qa e preencha senhas (NÃO commitar .env.qa)
#
# Aplicação: TDM-QA
# Namespace OpenShift (ARC-NPRD): automation-tdm-qa
# Conta de serviço: AUTOMACAOQA
# MySQL: ATDMQX01.local (10.101.37.168) — banco tdm_qa
# Redis: ATDMQX02.local (10.101.37.169) — via Sentinel (master TDMQA)

APP_PROFILE=qa

PORT=3333
USE_MEMORY_QUEUE=0

# MySQL
DATABASE_DRIVER=mysql
# Preferir hostname (.local); IP direto pode dar ETIMEDOUT fora da rede do servidor
MYSQL_HOST=ATDMQX01.local
MYSQL_PORT=3306
MYSQL_DATABASE=tdm_qa
MYSQL_USER=automacaoqa
MYSQL_PASSWORD=alterar_senha_mysql

# Redis Sentinel (obrigatório em QA — não usar conexão direta em produção)
REDIS_MODE=sentinel
REDIS_SENTINEL_HOST=ATDMQX02.local
REDIS_SENTINEL_PORT=26379
REDIS_MASTER_NAME=TDMQA
REDIS_PASSWORD=alterar_senha_redis
# REDIS_SENTINEL_PASSWORD=  # se diferente da senha do master

WORKER_CONCURRENCY=1
JOB_ATTEMPTS=2

AUTH_MODE=ldap
LDAP_URL=ldap://10.101.0.13:389
LDAP_DOMAIN=CORPORATIVO
# Admin da plataforma fixo no código: VT422570 (não alterável via .env)
SESSION_SECRET=definir-segredo-forte
