# Desenvolvimento local — copie para .env.local (gitignore)
APP_PROFILE=local

PORT=3333
USE_MEMORY_QUEUE=1

DATABASE_DRIVER=sqlite

# Redis local opcional (docker run -d -p 6379:6379 redis:alpine)
# USE_MEMORY_QUEUE=0
# REDIS_MODE=standalone
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

WORKER_CONCURRENCY=1
JOB_ATTEMPTS=2

AUTH_MODE=local
